FROM node:22-slim

# openssl/ca-certificates: required by Prisma's query engine on Debian slim images.
RUN apt-get update -y && apt-get install -y --no-install-recommends openssl ca-certificates \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

RUN corepack enable

# Copy only manifest files first so this layer is cached across rebuilds.
# --ignore-scripts: prisma/schema.prisma isn't copied in yet at this point
# (only manifests, for layer caching), so package.json's
# `postinstall: prisma generate` would fail on a from-scratch build —
# confirmed live via the production Dockerfile hitting the identical issue.
# `pnpm run prisma:generate` after COPY . . below covers it once the schema
# is actually present.
COPY package.json pnpm-lock.yaml* ./
RUN pnpm install --frozen-lockfile --ignore-scripts || pnpm install --ignore-scripts

COPY . .
RUN pnpm exec prisma generate

EXPOSE 3000

CMD ["pnpm", "exec", "next", "dev", "-H", "0.0.0.0", "-p", "3000"]
