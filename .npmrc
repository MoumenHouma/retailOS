# Windows packaging (desktop/Tauri build): pnpm's default virtual-store
# folder naming concatenates every peer dependency into the directory
# name (e.g. "next@16.2.10_@babel+core@..._react-dom@19_<hash>"), which
# for heavily peer-depended packages exceeds Windows' 260-char MAX_PATH
# once nested under the app's own install path -- confirmed live via
# makensis failing to open a real (non-test, non-excludable) file inside
# next/dist/compiled at exactly 260 chars. This caps long names down to
# a short hash instead, with no effect on module resolution.
virtual-store-dir-max-length=60
