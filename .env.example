# Database — two roles so Row-Level Security is actually enforced.
# DATABASE_URL: superuser, used ONLY by Prisma CLI (generate/migrate/seed). Never used by the running app.
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/retailos
# DATABASE_APP_URL: RLS-restricted role, used by the running app's Prisma client at runtime.
DATABASE_APP_URL=postgresql://app_user:app_user_dev_password@postgres:5432/retailos

POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=retailos

DATABASE_POOL_SIZE=20

# Redis
REDIS_URL=redis://redis:6379

# Auth
NEXTAUTH_SECRET=change-me-to-a-random-32-char-string
NEXTAUTH_URL=http://localhost:3000
JWT_EXPIRATION=24h
JWT_REFRESH_EXPIRATION=7d
BCRYPT_SALT_ROUNDS=12

# Object storage (MinIO in dev)
S3_ENDPOINT=http://minio:9000
S3_BUCKET=retailos
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin

# AI Engine (Phase 5 Chunk A) — python-ai never gets a DATABASE_URL, see
# ai-engine/app/config.py. INTERNAL_TOKEN is a shared bearer secret between
# the Next.js worker and python-ai; only reachable inside the Docker network.
AI_ENGINE_URL=http://python-ai:8000
INTERNAL_TOKEN=change-me-to-a-random-internal-token

# Realtime (Phase 5 Chunk A) — standalone Socket.io server, see
# src/server/realtime/server.ts. NEXT_PUBLIC_ prefix means this is inlined
# into the client bundle at build time — must be reachable from the
# browser, not just inside the Docker network (unlike AI_ENGINE_URL above).
NEXT_PUBLIC_REALTIME_URL=http://localhost:4001

# App
APP_URL=http://localhost:3000
APP_NAME=RetailOS
DEFAULT_LOCALE=fr
DEFAULT_CURRENCY=DZD
DEFAULT_TVA_RATE=19
