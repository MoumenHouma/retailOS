# Database — two roles so Row-Level Security is actually enforced.
# DATABASE_URL: superuser, used by Prisma CLI (generate/migrate/seed) and by
# prismaSuperuser at runtime (register, login, health-check). connection_limit
# kept low — few call sites, don't need a big pool.
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/retailos?connection_limit=5&pool_timeout=10
# DATABASE_APP_URL: RLS-restricted role, used by the running app's Prisma client at runtime.
# connection_limit is explicit here because Prisma does NOT read DATABASE_POOL_SIZE
# or any custom env var for pool sizing — it only reads `connection_limit` from
# this URL's query string. Without it, Prisma falls back to num_cpus*2+1 (5 on a
# 2-CPU container), which the dashboard's parallel-query load saturates instantly.
DATABASE_APP_URL=postgresql://app_user:app_user_dev_password@postgres:5432/retailos?connection_limit=20&pool_timeout=10

POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=retailos

# Redis
REDIS_URL=redis://redis:6379

# Auth
NEXTAUTH_SECRET=change-me-to-a-random-32-char-string
NEXTAUTH_URL=http://localhost:3000
JWT_EXPIRATION=24h
JWT_REFRESH_EXPIRATION=7d
BCRYPT_SALT_ROUNDS=12

# Object storage (MinIO in dev)
S3_ENDPOINT=http://minio:9000
S3_BUCKET=retailos
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin

# AI Engine (Phase 5 Chunk A) — python-ai never gets a DATABASE_URL, see
# ai-engine/app/config.py. INTERNAL_TOKEN is a shared bearer secret between
# the Next.js worker and python-ai; only reachable inside the Docker network.
AI_ENGINE_URL=http://python-ai:8000
INTERNAL_TOKEN=change-me-to-a-random-internal-token

# Realtime (Phase 5 Chunk A) — standalone Socket.io server, see
# src/server/realtime/server.ts. NEXT_PUBLIC_ prefix means this is inlined
# into the client bundle at build time — must be reachable from the
# browser, not just inside the Docker network (unlike AI_ENGINE_URL above).
NEXT_PUBLIC_REALTIME_URL=http://localhost:4001

# App
APP_URL=http://localhost:3000
APP_NAME=RetailOS
DEFAULT_LOCALE=fr
DEFAULT_CURRENCY=DZD
DEFAULT_TVA_RATE=19

# Email (Phase 6 Chunk A) — scheduled report delivery via src/lib/email.ts.
# Empty SMTP_HOST is the dev default: sendEmail() logs the would-be send
# instead of throwing, so scheduled reports can be verified without real
# credentials. Set these to activate real delivery.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@retailos.local

# Error tracking (Phase 6 Chunk D) — @sentry/nextjs no-ops when unset, this
# is standard SDK behavior, not a custom guard. Point at Sentry SaaS,
# self-hosted Sentry, or GlitchTip (open-source, Sentry-API-compatible).
SENTRY_DSN=
