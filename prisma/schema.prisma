/// as the denormalized running balances.
model CustomerDebtPayment {
  id            String            @id @default(uuid()) @db.Uuid
  tenantId      String            @default(dbgenerated("NULLIF(current_setting('app.current_tenant_id'::text, true), ''::text)::uuid")) @map("tenant_id") @db.Uuid
  debtId        String            @map("debt_id") @db.Uuid
  amount        Int
  paymentMethod PaymentMethodType @map("payment_method")
  reference     String?           @db.VarChar(100)
  paidAt        DateTime          @map("paid_at")
  recordedBy    String?           @map("recorded_by") @db.Uuid
  createdAt     DateTime          @default(now()) @map("created_at")

  tenant         Tenant       @relation(fields: [tenantId], references: [id])
  debt           CustomerDebt @relation(fields: [debtId], references: [id])
  recordedByUser User?        @relation("CustomerDebtPaymentRecordedBy", fields: [recordedBy], references: [id])

  @@index([tenantId])
  @@index([debtId])
  @@map("customer_debt_payments")
}

/// Net-new — not named in either source doc, a genuine schema gap like
/// Phase 3's SupplierQuote. A flat per-customer-per-product override, same
/// shape as SupplierProduct's per-relationship pricing row. Consumed by
/// sales.ts's priceItems() at checkout time (see the Decision in
/// PHASE4_FINANCE_PLAN.md Chunk B) — a row with no consumer would be an
/// inert data-entry screen.
model CustomerPrice {
  id         String   @id @default(uuid()) @db.Uuid
  tenantId   String   @default(dbgenerated("NULLIF(current_setting('app.current_tenant_id'::text, true), ''::text)::uuid")) @map("tenant_id") @db.Uuid
  customerId String   @map("customer_id") @db.Uuid
  productId  String   @map("product_id") @db.Uuid
  price      Int
  isActive   Boolean  @default(true) @map("is_active")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  tenant   Tenant   @relation(fields: [tenantId], references: [id])
  customer Customer @relation(fields: [customerId], references: [id])
  product  Product  @relation(fields: [productId], references: [id])

  @@unique([tenantId, customerId, productId])
  @@index([tenantId])
  @@map("customer_prices")
}

