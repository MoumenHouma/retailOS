  reference     String?           @db.VarChar(100)
  createdAt     DateTime          @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id])
  sale   Sale   @relation(fields: [saleId], references: [id])

  @@index([tenantId])
  @@index([saleId])
  @@map("sale_payments")
}

