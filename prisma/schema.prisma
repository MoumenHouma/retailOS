  tenantId      String            @default(dbgenerated("NULLIF(current_setting('app.current_tenant_id'::text, true), ''::text)::uuid")) @map("tenant_id") @db.Uuid
  invoiceId     String            @map("invoice_id") @db.Uuid
  amount        Int
  paymentMethod PaymentMethodType @map("payment_method")
  reference     String?           @db.VarChar(100)
  paidAt        DateTime          @map("paid_at")
  recordedBy    String?           @map("recorded_by") @db.Uuid
  createdAt     DateTime          @default(now()) @map("created_at")

  tenant         Tenant  @relation(fields: [tenantId], references: [id])
  invoice        Invoice @relation(fields: [invoiceId], references: [id])
  recordedByUser User?   @relation("InvoicePaymentRecordedBy", fields: [recordedBy], references: [id])

  @@index([tenantId])
  @@index([invoiceId])
  @@map("invoice_payments")
