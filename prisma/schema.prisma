// RetailOS — Phase 0 schema (Auth & Tenancy foundation).
//
// Conventions (see DATABASE.md §1):
// - All ids are UUID v4.
// - Tenant-scoped tables have `tenantId` (indexed) and are protected by a
//   PostgreSQL Row-Level Security policy (added by hand in the first
//   migration's SQL — Prisma has no native RLS/CHECK/GRANT syntax).
// - Soft delete only: `deletedAt`, never a hard DELETE.
// - Monetary values (introduced in later phases) are always Int in centimes.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // Used by the Prisma CLI only (generate/migrate/seed), connects as the
  // `postgres` superuser. The running app connects separately as `app_user`
  // via DATABASE_APP_URL — see src/lib/prisma.ts.
  url      = env("DATABASE_URL")
}

enum SubscriptionStatus {
  trial
  active
  suspended
  cancelled

  @@map("subscription_status_enum")
}

/// Platform-level table — no tenant_id (it *is* the tenant). RLS is
/// deliberately left off; the app layer restricts access to the session's
/// own tenant row (`WHERE id = session.tenantId`).
model Tenant {
  id                  String             @id @default(uuid()) @db.Uuid
  name                String             @db.VarChar(255)
  slug                String             @unique @db.VarChar(100)
  logoUrl             String?            @map("logo_url") @db.VarChar(500)
  nif                 String             @unique @db.VarChar(20)
  nis                 String             @db.VarChar(20)
  rc                  String             @db.VarChar(30)
  ai                  String?            @db.VarChar(30)
  formeJuridique      String?            @map("forme_juridique") @db.VarChar(50)
  address             String?
  city                String?            @db.VarChar(100)
  wilaya              String?            @db.VarChar(100)
  phone               String?            @db.VarChar(20)
  email               String?            @db.VarChar(255)
  website             String?            @db.VarChar(500)
  activitySector      String?            @map("activity_sector") @db.VarChar(100)
  tvaDefaultRate      Int                @default(19) @map("tva_default_rate") @db.SmallInt
  currency            String             @default("DZD") @db.VarChar(3)
  locale              String             @default("fr-DZ") @db.VarChar(5)
  subscriptionPlan    String             @default("starter") @map("subscription_plan") @db.VarChar(50)
  subscriptionStatus  SubscriptionStatus @default(active) @map("subscription_status")
  subscriptionEndsAt  DateTime?          @map("subscription_ends_at")
  settings            Json               @default("{}")
  isActive            Boolean            @default(true) @map("is_active")
  createdAt           DateTime           @default(now()) @map("created_at")
  updatedAt           DateTime           @updatedAt @map("updated_at")
  deletedAt           DateTime?          @map("deleted_at")

  stores           Store[]
  users            User[]
  roles            Role[]
  productCategories ProductCategory[]
  brands           Brand[]
  units            Unit[]
  products         Product[]
  productBarcodes  ProductBarcode[]
  stockMovements   StockMovement[]
  stockLevels      StockLevel[]
  suppliers        Supplier[]
  supplierContacts SupplierContact[]
  supplierProducts SupplierProduct[]
  customers        Customer[]
  posSessions      PosSession[]
  posCashMovements PosCashMovement[]
  sales            Sale[]
  saleItems        SaleItem[]
  salePayments     SalePayment[]

  @@map("tenants")
}

model Store {
  id        String    @id @default(uuid()) @db.Uuid
  tenantId  String    @map("tenant_id") @db.Uuid
  name      String    @db.VarChar(255)
  address   String?
  city      String?   @db.VarChar(100)
  wilaya    String?   @db.VarChar(100)
  phone     String?   @db.VarChar(20)
  email     String?   @db.VarChar(255)
  isMain    Boolean   @default(false) @map("is_main")
  posPrefix String    @default("POS") @map("pos_prefix") @db.VarChar(5)
  // Incremented (not read) inside the same withTenant transaction as sale
  // creation — the UPDATE's row lock serializes concurrent cashiers on the
  // same store, giving gapless per-store sale numbers without a separate
  // sequence/counter table or raw SQL row-locking.
  saleCounter Int     @default(0) @map("sale_counter")
  settings  Json      @default("{}")
  isActive  Boolean   @default(true) @map("is_active")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  tenant         Tenant          @relation(fields: [tenantId], references: [id])
  userRoles      UserRole[]
  userStores     UserStore[]
  stockMovements StockMovement[]
  stockLevels    StockLevel[]
  posSessions    PosSession[]
  sales          Sale[]

  @@index([tenantId])
  @@index([tenantId, isMain])
  @@map("stores")
}

model User {
  id                   String    @id @default(uuid()) @db.Uuid
  tenantId             String    @map("tenant_id") @db.Uuid
  email                String    @unique @db.VarChar(255)
  passwordHash         String    @map("password_hash") @db.VarChar(255)
  firstName            String    @map("first_name") @db.VarChar(100)
  lastName             String    @map("last_name") @db.VarChar(100)
  phone                String?   @db.VarChar(20)
  avatarUrl            String?   @map("avatar_url") @db.VarChar(500)
  isActive             Boolean   @default(true) @map("is_active")
  emailVerifiedAt      DateTime? @map("email_verified_at")
  lastLoginAt          DateTime? @map("last_login_at")
  failedLoginAttempts  Int       @default(0) @map("failed_login_attempts")
  lockedUntil          DateTime? @map("locked_until")
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")
  deletedAt             DateTime? @map("deleted_at")

  tenant          Tenant      @relation(fields: [tenantId], references: [id])
  userRoles       UserRole[]
  userStores      UserStore[]
  productsCreated       Product[]       @relation("ProductCreatedBy")
  productsUpdated       Product[]       @relation("ProductUpdatedBy")
  stockMovementsCreated StockMovement[] @relation("StockMovementCreatedBy")
  posSessionsAsCashier      PosSession[]      @relation("PosSessionCashier")
  posCashMovementsCreated   PosCashMovement[] @relation("PosCashMovementCreatedBy")
  salesAsCashier            Sale[]            @relation("SaleCashier")

  @@index([tenantId])
  @@map("users")
}

model Role {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @map("tenant_id") @db.Uuid
  name        String   @db.VarChar(50)
  description String?
  isSystem    Boolean  @default(false) @map("is_system")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  tenant          Tenant           @relation(fields: [tenantId], references: [id])
  rolePermissions RolePermission[]
  userRoles       UserRole[]

  @@unique([tenantId, name])
  @@map("roles")
}

/// Global permission catalog — no tenantId, shared across all tenants.
model Permission {
  id          String   @id @default(uuid()) @db.Uuid
  name        String   @unique @db.VarChar(100)
  description String?
  module      String   @db.VarChar(50)
  createdAt   DateTime @default(now()) @map("created_at")

  rolePermissions RolePermission[]

  @@index([module])
  @@map("permissions")
}

model RolePermission {
  roleId       String @map("role_id") @db.Uuid
  permissionId String @map("permission_id") @db.Uuid

  role       Role       @relation(fields: [roleId], references: [id])
  permission Permission @relation(fields: [permissionId], references: [id])

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

/// storeId is nullable ("role applies to all stores in tenant" per
/// DATABASE.md §4.7). A composite PK with a nullable column is awkward in
/// Postgres, so this table gets its own surrogate id plus a regular unique
/// index instead of `@@id([userId, roleId, storeId])`.
model UserRole {
  id       String  @id @default(uuid()) @db.Uuid
  userId   String  @map("user_id") @db.Uuid
  roleId   String  @map("role_id") @db.Uuid
  storeId  String? @map("store_id") @db.Uuid

  user  User   @relation(fields: [userId], references: [id])
  role  Role   @relation(fields: [roleId], references: [id])
  store Store? @relation(fields: [storeId], references: [id])

  @@unique([userId, roleId, storeId])
  @@map("user_roles")
}

model UserStore {
  userId  String @map("user_id") @db.Uuid
  storeId String @map("store_id") @db.Uuid

  user  User  @relation(fields: [userId], references: [id])
  store Store @relation(fields: [storeId], references: [id])

  @@id([userId, storeId])
  @@map("user_stores")
}

// --- Phase 1: Product Management ---------------------------------------

/// Hierarchical category tree (adjacency list via parentId). A product
/// belongs to at most one category (DATABASE.md §5.1 / ARCHITECTURE.md §4.2).
/// Uniqueness of (tenantId, name) is soft-delete-aware (partial index,
/// WHERE deletedAt IS NULL) — hand-appended in migration.sql, not expressible
/// via @@unique here (would block name reuse after a soft delete).
model ProductCategory {
  id          String    @id @default(uuid()) @db.Uuid
  tenantId    String    @default(dbgenerated("NULLIF(current_setting('app.current_tenant_id'::text, true), ''::text)::uuid")) @map("tenant_id") @db.Uuid
  parentId    String?   @map("parent_id") @db.Uuid
  name        String    @db.VarChar(255)
  nameAr      String?   @map("name_ar") @db.VarChar(255)
  nameEn      String?   @map("name_en") @db.VarChar(255)
  description String?
  imageUrl    String?   @map("image_url") @db.VarChar(500)
  sortOrder   Int       @default(0) @map("sort_order")
  isActive    Boolean   @default(true) @map("is_active")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  tenant   Tenant            @relation(fields: [tenantId], references: [id])
  parent   ProductCategory?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children ProductCategory[] @relation("CategoryHierarchy")
  products Product[]

  @@index([tenantId])
  @@index([parentId])
  @@map("product_categories")
}

model Brand {
  id          String    @id @default(uuid()) @db.Uuid
  tenantId    String    @default(dbgenerated("NULLIF(current_setting('app.current_tenant_id'::text, true), ''::text)::uuid")) @map("tenant_id") @db.Uuid
  name        String    @db.VarChar(255)
  country     String?   @db.VarChar(100)
  description String?
  isActive    Boolean   @default(true) @map("is_active")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  tenant   Tenant    @relation(fields: [tenantId], references: [id])
  products Product[]

  @@index([tenantId])
  @@map("brands")
}

model Unit {
  id           String    @id @default(uuid()) @db.Uuid
  tenantId     String    @default(dbgenerated("NULLIF(current_setting('app.current_tenant_id'::text, true), ''::text)::uuid")) @map("tenant_id") @db.Uuid
  name         String    @db.VarChar(50)
  abbreviation String    @db.VarChar(10)
  isBaseUnit   Boolean   @default(false) @map("is_base_unit")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  deletedAt    DateTime? @map("deleted_at")

  tenant   Tenant    @relation(fields: [tenantId], references: [id])
  products Product[]

  @@index([tenantId])
  @@map("units")
}

model Product {
  id             String    @id @default(uuid()) @db.Uuid
  tenantId       String    @default(dbgenerated("NULLIF(current_setting('app.current_tenant_id'::text, true), ''::text)::uuid")) @map("tenant_id") @db.Uuid
  sku            String?   @db.VarChar(50)
  name           String    @db.VarChar(500)
  nameAr         String?   @map("name_ar") @db.VarChar(500)
  nameEn         String?   @map("name_en") @db.VarChar(500)
  description    String?
  categoryId     String?   @map("category_id") @db.Uuid
  brandId        String?   @map("brand_id") @db.Uuid
  unitId         String    @map("unit_id") @db.Uuid
  barcode        String?   @db.VarChar(20)
  costPrice      Int?      @map("cost_price")
  sellingPrice   Int       @map("selling_price")
  wholesalePrice Int?      @map("wholesale_price")
  minPrice       Int?      @map("min_price")
  tvaRate        Int       @default(19) @map("tva_rate") @db.SmallInt
  isTaxable      Boolean   @default(true) @map("is_taxable")
  isTrackable    Boolean   @default(true) @map("is_trackable")
  isExpirable    Boolean   @default(false) @map("is_expirable")
  shelfLifeDays  Int?      @map("shelf_life_days")
  minStockLevel  Int       @default(0) @map("min_stock_level")
  maxStockLevel  Int?      @map("max_stock_level")
  // reorderPoint/safetyStock stay null in Phase 1 — computed by the AI/
  // optimization engine, which doesn't exist until Phase 5.
  reorderPoint Int?      @map("reorder_point")
  safetyStock  Int?      @map("safety_stock")
  imageUrl     String?   @map("image_url") @db.VarChar(500)
  isActive     Boolean   @default(true) @map("is_active")
  createdBy    String?   @map("created_by") @db.Uuid
  updatedBy    String?   @map("updated_by") @db.Uuid
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  deletedAt    DateTime? @map("deleted_at")

  tenant        Tenant            @relation(fields: [tenantId], references: [id])
  category      ProductCategory?  @relation(fields: [categoryId], references: [id])
  brand         Brand?            @relation(fields: [brandId], references: [id])
  unit          Unit              @relation(fields: [unitId], references: [id])
  createdByUser  User?            @relation("ProductCreatedBy", fields: [createdBy], references: [id])
  updatedByUser  User?            @relation("ProductUpdatedBy", fields: [updatedBy], references: [id])
  barcodes         ProductBarcode[]
  stockMovements   StockMovement[]
  stockLevels      StockLevel[]
  supplierProducts SupplierProduct[]
  saleItems        SaleItem[]

  @@index([tenantId])
  @@index([barcode])
  @@index([sku])
  @@index([categoryId])
  @@index([brandId])
  @@map("products")
  // name GIN trgm index hand-appended in migration.sql — pg_trgm has no
  // Prisma-native index-type syntax, same "hand-append what Prisma can't
  // express" rule already used for RLS/CHECK constraints project-wide.
}

model ProductBarcode {
  id          String    @id @default(uuid()) @db.Uuid
  tenantId    String    @default(dbgenerated("NULLIF(current_setting('app.current_tenant_id'::text, true), ''::text)::uuid")) @map("tenant_id") @db.Uuid
  productId   String    @map("product_id") @db.Uuid
  barcode     String    @db.VarChar(20)
  barcodeType String    @default("EAN13") @map("barcode_type") @db.VarChar(20)
  isPrimary   Boolean   @default(false) @map("is_primary")
  createdAt   DateTime  @default(now()) @map("created_at")
  deletedAt   DateTime? @map("deleted_at")

  tenant  Tenant  @relation(fields: [tenantId], references: [id])
  product Product @relation(fields: [productId], references: [id])

  @@index([tenantId])
  @@index([productId])
  @@map("product_barcodes")
}

// --- Phase 1: Inventory Core ---------------------------------------------

/// All 9 values modeled since stock_movements is a shared table future
/// phases will insert into (POS sales, purchasing, transfers) — only
/// ADJUSTMENT_IN/ADJUSTMENT_OUT are reachable via UI in Phase 1.
enum StockMovementType {
  PURCHASE_IN
  SALE_OUT
  TRANSFER_OUT
  TRANSFER_IN
  ADJUSTMENT_IN
  ADJUSTMENT_OUT
  RETURN_IN
  RETURN_OUT
  WRITE_OFF

  @@map("stock_movement_type_enum")
}

/// Immutable log — the application only ever INSERTs here. A database
/// trigger (fn_apply_stock_movement, hand-appended in migration.sql)
/// maintains `stock_levels` and rejects movements that would make on-hand
/// quantity negative (ARCHITECTURE.md §4.3).
model StockMovement {
  id            String            @id @default(uuid()) @db.Uuid
  tenantId      String            @default(dbgenerated("NULLIF(current_setting('app.current_tenant_id'::text, true), ''::text)::uuid")) @map("tenant_id") @db.Uuid
  productId     String            @map("product_id") @db.Uuid
  storeId       String            @map("store_id") @db.Uuid
  movementType  StockMovementType @map("movement_type")
  quantity      Int
  referenceId   String?           @map("reference_id") @db.Uuid
  referenceType String?           @map("reference_type") @db.VarChar(50)
  // No FK — product_batches doesn't exist until Phase 3; always null for now.
  batchId   String?  @map("batch_id") @db.Uuid
  notes     String?
  createdBy String?  @map("created_by") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")

  tenant        Tenant  @relation(fields: [tenantId], references: [id])
  product       Product @relation(fields: [productId], references: [id])
  store         Store   @relation(fields: [storeId], references: [id])
  createdByUser User?   @relation("StockMovementCreatedBy", fields: [createdBy], references: [id])

  @@index([tenantId])
  @@index([productId])
  @@index([storeId])
  @@index([movementType])
  @@index([createdAt])
  @@index([productId, storeId, createdAt])
  @@map("stock_movements")
}

/// Denormalized, trigger-maintained — the application never writes here
/// directly, only ever INSERTs into StockMovement. `quantityAvailable` is a
/// Postgres GENERATED ALWAYS AS (quantity_on_hand - quantity_reserved)
/// STORED column; Prisma has no syntax for this, hand-patched in
/// migration.sql — re-check any future migration touching this table since
/// `prisma migrate dev --create-only` may try to "fix" it back to a plain column.
model StockLevel {
  id                String    @id @default(uuid()) @db.Uuid
  tenantId          String    @default(dbgenerated("NULLIF(current_setting('app.current_tenant_id'::text, true), ''::text)::uuid")) @map("tenant_id") @db.Uuid
  productId         String    @map("product_id") @db.Uuid
  storeId           String    @map("store_id") @db.Uuid
  quantityOnHand    Int       @default(0) @map("quantity_on_hand")
  quantityReserved  Int       @default(0) @map("quantity_reserved")
  quantityAvailable Int       @map("quantity_available")
  lastMovementAt    DateTime? @map("last_movement_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  tenant  Tenant  @relation(fields: [tenantId], references: [id])
  product Product @relation(fields: [productId], references: [id])
  store   Store   @relation(fields: [storeId], references: [id])

  @@unique([tenantId, productId, storeId])
  @@map("stock_levels")
}

// --- Phase 1: Supplier Management ----------------------------------------

model Supplier {
  id            String    @id @default(uuid()) @db.Uuid
  tenantId      String    @default(dbgenerated("NULLIF(current_setting('app.current_tenant_id'::text, true), ''::text)::uuid")) @map("tenant_id") @db.Uuid
  name          String    @db.VarChar(255)
  nif           String?   @db.VarChar(20)
  rc            String?   @db.VarChar(30)
  contactPerson String?   @map("contact_person") @db.VarChar(255)
  phone         String?   @db.VarChar(20)
  email         String?   @db.VarChar(255)
  address       String?
  city          String?   @db.VarChar(100)
  wilaya        String?   @db.VarChar(100)
  bankName      String?   @map("bank_name") @db.VarChar(255)
  bankAccount   String?   @map("bank_account") @db.VarChar(100)
  paymentTerms  Int       @default(0) @map("payment_terms")
  leadTimeDays  Int       @default(3) @map("lead_time_days")
  // MCDA composite score — stays null in Phase 1, no AI/optimization engine
  // until Phase 5.
  rating    Decimal?  @db.Decimal(3, 2)
  notes     String?
  isActive  Boolean   @default(true) @map("is_active")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  tenant           Tenant            @relation(fields: [tenantId], references: [id])
  contacts         SupplierContact[]
  supplierProducts SupplierProduct[]

  @@index([tenantId])
  @@map("suppliers")
}

/// No deletedAt — matches DATABASE.md §8.2 verbatim; hard delete is fine
/// here, nothing depends on a soft-delete-aware partial index for contacts.
model SupplierContact {
  id         String  @id @default(uuid()) @db.Uuid
  tenantId   String  @default(dbgenerated("NULLIF(current_setting('app.current_tenant_id'::text, true), ''::text)::uuid")) @map("tenant_id") @db.Uuid
  supplierId String  @map("supplier_id") @db.Uuid
  name       String  @db.VarChar(255)
  role       String? @db.VarChar(100)
  phone      String? @db.VarChar(20)
  email      String? @db.VarChar(255)
  isPrimary  Boolean @default(false) @map("is_primary")

  tenant   Tenant   @relation(fields: [tenantId], references: [id])
  supplier Supplier @relation(fields: [supplierId], references: [id])

  @@index([tenantId])
  @@index([supplierId])
  @@map("supplier_contacts")
}

model SupplierProduct {
  id                  String   @id @default(uuid()) @db.Uuid
  tenantId            String   @default(dbgenerated("NULLIF(current_setting('app.current_tenant_id'::text, true), ''::text)::uuid")) @map("tenant_id") @db.Uuid
  supplierId          String   @map("supplier_id") @db.Uuid
  productId           String   @map("product_id") @db.Uuid
  supplierSku         String?  @map("supplier_sku") @db.VarChar(100)
  supplierProductName String?  @map("supplier_product_name") @db.VarChar(500)
  unitPrice           Int?     @map("unit_price")
  minOrderQuantity    Int      @default(1) @map("min_order_quantity")
  deliveryTimeDays    Int?     @map("delivery_time_days")
  isPreferred         Boolean  @default(false) @map("is_preferred")
  updatedAt           DateTime @updatedAt @map("updated_at")

  tenant   Tenant   @relation(fields: [tenantId], references: [id])
  supplier Supplier @relation(fields: [supplierId], references: [id])
  product  Product  @relation(fields: [productId], references: [id])

  @@unique([tenantId, supplierId, productId])
  @@map("supplier_products")
}

// --- Phase 2 Chunk A: POS Core -------------------------------------------

enum CustomerType {
  walk_in
  regular
  vip
  wholesale

  @@map("customer_type_enum")
}

/// Minimal for Chunk A — just enough for a POS sale to reference "who this
/// sale is for". Loyalty/debt/segmentation columns (DATABASE.md §10) are
/// deferred to whichever later phase actually needs them.
model Customer {
  id           String       @id @default(uuid()) @db.Uuid
  tenantId     String       @default(dbgenerated("NULLIF(current_setting('app.current_tenant_id'::text, true), ''::text)::uuid")) @map("tenant_id") @db.Uuid
  name         String       @db.VarChar(500)
  phone        String?      @db.VarChar(20)
  customerType CustomerType @default(walk_in) @map("customer_type")
  isActive     Boolean      @default(true) @map("is_active")
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")
  deletedAt    DateTime?    @map("deleted_at")

  tenant Tenant @relation(fields: [tenantId], references: [id])
  sales  Sale[]

  @@index([tenantId])
  @@map("customers")
}

enum PosSessionStatus {
  open
  closed

  @@map("pos_session_status_enum")
}

/// Cashier shift. A Sale can only be completed while its terminal has an
/// open PosSession (enforced in the sales service, not the DB) — see
/// SessionClosedError in src/server/services/pos-sessions.ts.
model PosSession {
  id             String           @id @default(uuid()) @db.Uuid
  tenantId       String           @default(dbgenerated("NULLIF(current_setting('app.current_tenant_id'::text, true), ''::text)::uuid")) @map("tenant_id") @db.Uuid
  storeId        String           @map("store_id") @db.Uuid
  cashierId      String           @map("cashier_id") @db.Uuid
  terminalName   String           @map("terminal_name") @db.VarChar(50)
  openedAt       DateTime         @default(now()) @map("opened_at")
  closedAt       DateTime?        @map("closed_at")
  openingCash    Int              @map("opening_cash")
  closingCash    Int?             @map("closing_cash")
  expectedCash   Int?             @map("expected_cash")
  cashDifference Int?             @map("cash_difference")
  totalSales     Int              @default(0) @map("total_sales")
  totalRefunds   Int              @default(0) @map("total_refunds")
  status         PosSessionStatus @default(open)

  tenant        Tenant            @relation(fields: [tenantId], references: [id])
  store         Store             @relation(fields: [storeId], references: [id])
  cashier       User              @relation("PosSessionCashier", fields: [cashierId], references: [id])
  cashMovements PosCashMovement[]
  sales         Sale[]

  @@index([tenantId])
  @@index([storeId])
  @@index([cashierId])
  @@map("pos_sessions")
}

enum CashMovementType {
  OPENING
  CLOSING
  WITHDRAWAL
  DEPOSIT
  ADJUSTMENT

  @@map("cash_movement_type_enum")
}

model PosCashMovement {
  id           String            @id @default(uuid()) @db.Uuid
  tenantId     String            @default(dbgenerated("NULLIF(current_setting('app.current_tenant_id'::text, true), ''::text)::uuid")) @map("tenant_id") @db.Uuid
  sessionId    String            @map("session_id") @db.Uuid
  movementType CashMovementType  @map("movement_type")
  amount       Int
  reason       String?
  createdBy    String            @map("created_by") @db.Uuid
  createdAt    DateTime          @default(now()) @map("created_at")

  tenant        Tenant     @relation(fields: [tenantId], references: [id])
  session       PosSession @relation(fields: [sessionId], references: [id])
  createdByUser User       @relation("PosCashMovementCreatedBy", fields: [createdBy], references: [id])

  @@index([tenantId])
  @@index([sessionId])
  @@map("pos_cash_movements")
}

enum SaleStatus {
  completed
  voided
  held

  @@map("sale_status_enum")
}

model Sale {
  id             String     @id @default(uuid()) @db.Uuid
  tenantId       String     @default(dbgenerated("NULLIF(current_setting('app.current_tenant_id'::text, true), ''::text)::uuid")) @map("tenant_id") @db.Uuid
  storeId        String     @map("store_id") @db.Uuid
  saleNumber     String     @map("sale_number") @db.VarChar(50)
  posSessionId   String?    @map("pos_session_id") @db.Uuid
  customerId     String?    @map("customer_id") @db.Uuid
  cashierId      String     @map("cashier_id") @db.Uuid
  subtotal       Int
  discountAmount Int        @default(0) @map("discount_amount")
  tvaAmount      Int        @map("tva_amount")
  // Only populated once Chunk C (invoicing) exists — every Chunk A/B sale
  // is a plain receipt, not a DÉCRET 05-468 facture.
  taxStampAmount Int        @default(0) @map("tax_stamp_amount")
  total          Int
  totalPaid      Int        @map("total_paid")
  changeDue      Int        @default(0) @map("change_due")
  status         SaleStatus @default(completed)
  isOffline      Boolean    @default(false) @map("is_offline")
  syncedAt       DateTime?  @map("synced_at")
  notes          String?
  createdAt      DateTime   @default(now()) @map("created_at")
  updatedAt      DateTime   @updatedAt @map("updated_at")
  deletedAt      DateTime?  @map("deleted_at")

  tenant     Tenant        @relation(fields: [tenantId], references: [id])
  store      Store         @relation(fields: [storeId], references: [id])
  posSession PosSession?   @relation(fields: [posSessionId], references: [id])
  customer   Customer?     @relation(fields: [customerId], references: [id])
  cashier    User          @relation("SaleCashier", fields: [cashierId], references: [id])
  items      SaleItem[]
  payments   SalePayment[]

  @@unique([tenantId, storeId, saleNumber])
  @@index([tenantId])
  @@index([storeId])
  @@index([cashierId])
  @@index([createdAt])
  @@map("sales")
}

model SaleItem {
  id             String  @id @default(uuid()) @db.Uuid
  tenantId       String  @default(dbgenerated("NULLIF(current_setting('app.current_tenant_id'::text, true), ''::text)::uuid")) @map("tenant_id") @db.Uuid
  saleId         String  @map("sale_id") @db.Uuid
  productId      String  @map("product_id") @db.Uuid
  productName    String  @map("product_name") @db.VarChar(500)
  productBarcode String? @map("product_barcode") @db.VarChar(20)
  quantity       Int
  unitPrice      Int     @map("unit_price")
  costPrice      Int?    @map("cost_price")
  tvaRate        Int     @map("tva_rate") @db.SmallInt
  discountAmount Int     @default(0) @map("discount_amount")
  subtotal       Int
  tvaAmount      Int     @map("tva_amount")
  total          Int
  // No FK — product_batches doesn't exist until Phase 3, always null for now
  // (same as StockMovement.batchId).
  batchId String? @map("batch_id") @db.Uuid

  tenant  Tenant  @relation(fields: [tenantId], references: [id])
  sale    Sale    @relation(fields: [saleId], references: [id])
  product Product @relation(fields: [productId], references: [id])

  @@index([tenantId])
  @@index([saleId])
  @@index([productId])
  @@map("sale_items")
}

enum PaymentMethodType {
  CASH
  CARD
  CHECK
  TRANSFER
  MIXED

  @@map("payment_method_enum")
}

model SalePayment {
  id            String            @id @default(uuid()) @db.Uuid
  tenantId      String            @default(dbgenerated("NULLIF(current_setting('app.current_tenant_id'::text, true), ''::text)::uuid")) @map("tenant_id") @db.Uuid
  saleId        String            @map("sale_id") @db.Uuid
  paymentMethod PaymentMethodType @map("payment_method")
  amount        Int
  reference     String?           @db.VarChar(100)
  createdAt     DateTime          @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id])
  sale   Sale   @relation(fields: [saleId], references: [id])

  @@index([tenantId])
  @@index([saleId])
  @@map("sale_payments")
}
