enum RecommendationType {
  reorder
  supplier_switch
  price_change
  markdown
  promotion
  staffing
  waste_prevention

  @@map("recommendation_type_enum")
}

enum Priority {
  low
  medium
  high
  urgent

  @@map("priority_enum")
}

/// Per DATABASE.md §12.3 verbatim. Doubles as the in-app AI notification
/// store (isRead/isActioned already give it that shape) — Chunk D's
/// "recommendations feed" is a read/filter UI over this table, not new
/// schema (see PHASE5_INTELLIGENCE_PLAN.md's divergence table).
model AiRecommendation {
  id                 String    @id @default(uuid()) @db.Uuid
  tenantId           String    @default(dbgenerated("NULLIF(current_setting('app.current_tenant_id'::text, true), ''::text)::uuid")) @map("tenant_id") @db.Uuid
  storeId            String?   @map("store_id") @db.Uuid
  recommendationType RecommendationType @map("recommendation_type")
  title              String    @db.VarChar(500)
  description        String
  data               Json
  priority           Priority  @default(medium)
  isRead             Boolean   @default(false) @map("is_read")
  isActioned         Boolean   @default(false) @map("is_actioned")
  expiresAt          DateTime? @map("expires_at")
  createdAt          DateTime  @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id])
  store  Store? @relation(fields: [storeId], references: [id])

  @@index([tenantId])
  @@index([tenantId, isRead])
  @@index([storeId])
  @@map("ai_recommendations")
}

// --- Phase 5 Chunk C: Supplier Ranking (MCDA) ------------------------------

enum EvaluationMethod {
  ahp_topsis
  ahp_promethee
  ahp_only
  topsis_only

  @@map("evaluation_method_enum")
}

/// Per DATABASE.md §12.1: one row per supplier per evaluation run, sharing
/// evaluationPeriod/criteriaWeights across the run. Deviation from the
/// doc's own example, documented: supplierScores there is illustrated
/// keyed by supplier *name* — this keys by supplierId (UUID) instead, since
/// names aren't stable/unique identifiers and every other JSONB payload in
/// this schema keys by id.
model SupplierEvaluation {
  id                String            @id @default(uuid()) @db.Uuid
  tenantId          String            @default(dbgenerated("NULLIF(current_setting('app.current_tenant_id'::text, true), ''::text)::uuid")) @map("tenant_id") @db.Uuid
  supplierId        String            @map("supplier_id") @db.Uuid
  evaluationPeriod  String            @map("evaluation_period") @db.VarChar(50)
  method            EvaluationMethod
  criteriaWeights   Json              @map("criteria_weights")
  supplierScores    Json              @map("supplier_scores")
  consistencyRatio  Decimal?          @map("consistency_ratio") @db.Decimal(5, 4)
  evaluatedAt       DateTime          @default(now()) @map("evaluated_at")
  evaluatedBy       String            @map("evaluated_by") @db.Uuid

  tenant          Tenant   @relation(fields: [tenantId], references: [id])
  supplier        Supplier @relation(fields: [supplierId], references: [id])
  evaluatedByUser User     @relation("SupplierEvaluationEvaluatedBy", fields: [evaluatedBy], references: [id])

  @@index([tenantId])
  @@index([supplierId])
  @@map("supplier_evaluations")
}

// --- Phase 6 Chunk A: Reports & BI -----------------------------------------
// Net-new — ARCHITECTURE.md §4.10 names report templates but gives zero
// schema for scheduling/dashboard config; DATABASE.md doesn't mention these
// tables at all. Designed from scratch here, same posture as Phase 3/4's
// genuine schema gaps.

enum ReportType {
  sales
  inventory
  purchase
  financial
  employee

  @@map("report_type_enum")
}

enum ReportExportFormat {
  pdf
  xlsx
  csv

  @@map("report_export_format_enum")
}

enum ReportFrequency {
  daily
  weekly
  monthly

  @@map("report_frequency_enum")
}

enum ReportRunStatus {
  success
  failed

  @@map("report_run_status_enum")
}

/// The five report templates (sales/inventory/purchase/financial/employee)
/// route to fixed service functions via reportType — no generic tenant-
/// configurable "Report" table, criteria stay in code (same precedent as
/// Phase 5 Chunk C's fixed MCDA criteria list).
model ScheduledReport {
  id              String             @id @default(uuid()) @db.Uuid
  tenantId        String             @default(dbgenerated("NULLIF(current_setting('app.current_tenant_id'::text, true), ''::text)::uuid")) @map("tenant_id") @db.Uuid
  reportType      ReportType         @map("report_type")
  name            String             @db.VarChar(200)
  filters         Json               @default("{}")
  format          ReportExportFormat
  frequency       ReportFrequency
  recipientEmails String[]           @map("recipient_emails")
  isActive        Boolean            @default(true) @map("is_active")
  lastRunAt       DateTime?          @map("last_run_at")
  lastRunStatus   ReportRunStatus?   @map("last_run_status")
  lastRunError    String?            @map("last_run_error")
  createdBy       String             @map("created_by") @db.Uuid
  createdAt       DateTime           @default(now()) @map("created_at")
  updatedAt       DateTime           @updatedAt @map("updated_at")
  deletedAt       DateTime?          @map("deleted_at")

  tenant          Tenant @relation(fields: [tenantId], references: [id])
  createdByUser   User   @relation("ScheduledReportCreatedBy", fields: [createdBy], references: [id])

  @@index([tenantId])
  @@index([tenantId, isActive])
  @@map("scheduled_reports")
}

/// Per-role (not per-user) KPI widget layout, matching ROADMAP.md's literal
/// "dashboard customization (per role)" wording. A user holding multiple
/// roles renders their first role's layout — cosmetic-only limitation,
/// acceptable since this doesn't gate access to anything.
model DashboardLayout {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @default(dbgenerated("NULLIF(current_setting('app.current_tenant_id'::text, true), ''::text)::uuid")) @map("tenant_id") @db.Uuid
  role      String   @db.VarChar(50)
  widgets   Json
  updatedAt DateTime @updatedAt @map("updated_at")
  updatedBy String   @map("updated_by") @db.Uuid

  tenant        Tenant @relation(fields: [tenantId], references: [id])
  updatedByUser User   @relation("DashboardLayoutUpdatedBy", fields: [updatedBy], references: [id])

  @@unique([tenantId, role])
  @@map("dashboard_layouts")
}
