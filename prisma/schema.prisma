enum DebtStatus {
  outstanding
  partially_paid
  paid
  written_off

  @@map("debt_status_enum")
}

/// Per DATABASE.md §10.3 verbatim. Models a credit sale with no invoice
/// ever generated — deliberately a separate ledger from InvoicePayment
/// (that one backs a formal DÉCRET-05-468 document; this backs the much
/// more common small-retail "customer tab").
model CustomerDebt {
  id         String     @id @default(uuid()) @db.Uuid
  tenantId   String     @default(dbgenerated("NULLIF(current_setting('app.current_tenant_id'::text, true), ''::text)::uuid")) @map("tenant_id") @db.Uuid
  customerId String     @map("customer_id") @db.Uuid
  amount     Int
  remaining  Int
  saleId     String?    @map("sale_id") @db.Uuid
  dueDate    DateTime?  @map("due_date") @db.Date
